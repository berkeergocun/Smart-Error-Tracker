# ─── MongoDB Credentials ─────────────────────────────────────────────────────
# Dokploy üzerinden deploy ediyorsanız güçlü bir şifre belirleyin
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change_this_password

# ─── OpenRouter API (AI Analiz) ───────────────────────────────────────────────
# Ücretsiz plan: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Production'da mutlaka uzun ve rastgele bir değer kullanın
JWT_SECRET=change_this_secret_in_production

# ─── URL Ayarları (Dokploy'da domain atadıktan sonra set edin) ───────────────
# Backend'in herkese açık adresi (tarayıcıdan erişilecek)
NUXT_PUBLIC_API_URL=https://api.your-domain.com

# Frontend'in herkese açık adresi (CORS için backend'e iletilir)
FRONTEND_URL=https://your-domain.com
