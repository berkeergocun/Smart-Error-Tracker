# ─── Opsiyonel: OpenAI API anahtarı (yoksa fallback analiz kullanılır) ───────
OPENAI_API_KEY=

# ─── JWT secret (production'da mutlaka değiştirin) ───────────────────────────
JWT_SECRET=change_this_secret_in_production

# ─── Frontend'in tarayıcıdan backend'e erişeceği URL ─────────────────────────
# Yerel geliştirme: http://localhost:3001
# Sunucu deploy: https://api.alanadi.com
NUXT_PUBLIC_API_URL=http://localhost:3001
