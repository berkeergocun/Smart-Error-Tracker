{
  "name": "smart-error-tracker-backend",
  "version": "1.0.0",
  "description": "Smart Error Tracker - Backend API (Bun + Elysia.js)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "seed": "bun run seed.ts"
  },
  "dependencies": {
    "elysia": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "mongoose": "^8.9.0",
    "openai": "^4.77.0",
    "uuid": "^11.0.5",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
